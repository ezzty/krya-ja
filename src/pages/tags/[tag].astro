---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NavBar from '../../components/NavBar.astro';
import { formatDate, withTrailingSlash } from '../../lib/utils';

export async function getStaticPaths() {
  const posts = (await getCollection('posts')).filter(post => !post.data.draft);
  
  const tagSet = new Set<string>();
  posts.forEach(post => {
    const tags = post.data.tags || [];
    tags.forEach(tag => tagSet.add(tag));
  });
  
  return Array.from(tagSet).map(tag => ({
    params: { tag },
    props: { tag }
  }));
}

const allPosts = (await getCollection('posts')).filter(post => !post.data.draft);
const { tag } = Astro.params;
const decodedTag = decodeURIComponent(tag!);

const posts = allPosts
  .filter(post => {
    const tags = post.data.tags || [];
    return tags.includes(decodedTag);
  })
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={`タグ：${decodedTag} | krya`}>
  <NavBar slot="header" />
  <div class="container">
    <div class="col-mb-12" id="main" role="main">
      <h1 class="tags-title">タグ：{decodedTag}</h1>
      {posts.length > 0 ? (
        <div class="post-list">
          {posts.map(post => (
            <article class="post-item">
              <h2 class="post-title-small">
                <a href={withTrailingSlash(`/post/${post.id.replace(/\.[^.]+$/, '')}`)}>{post.data.title}</a>
              </h2>
              <div class="post-meta">
                <span>{formatDate(post.data.pubDate.toISOString())}</span>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <p class="no-items">このタグの記事はまだありません</p>
      )}
    </div>
  </div>
</BaseLayout>
