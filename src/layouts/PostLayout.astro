---
import BaseLayout from './BaseLayout.astro';
import NavBar from '../components/NavBar.astro';
import { formatDate, withTrailingSlash } from '../lib/utils';

interface Props {
  title: string;
  description?: string;
  author: string;
  pubDate: string;
  wordCount?: number;
  tags?: string[];
  categories?: string[];
  thumbnail?: string;
}

const { title, description, author, pubDate, wordCount = 0, tags = [], categories = [], thumbnail } = Astro.props;

// 处理 og:image URL（无图时用站点默认图）
const ogImage = thumbnail || 'https://jp.krya.com/og-image.png';
const isDefaultOg = ogImage === 'https://jp.krya.com/og-image.png';
---

<BaseLayout
  title={title}
  description={description || 'Jinの個人ブログ'}
  image={ogImage}
  imageWidth={isDefaultOg ? 120 : undefined}
  imageHeight={isDefaultOg ? 120 : undefined}
  type="article"
>
  <NavBar slot="header" />
  
  <!-- 文章页 SEO 元数据 -->
  <meta slot="head" property="article:published_time" content={pubDate} />
  {tags.length > 0 && (
    <meta slot="head" property="article:tag" content={tags.join(', ')} />
  )}
  
  <script slot="head" is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": title,
    "author": {
      "@type": "Person",
      "name": author
    },
    "datePublished": pubDate,
    "description": Astro.props.description || '',
    "image": ogImage,
    "url": Astro.url.href
  })} />
  
  <div class="col-mb-12" id="main" role="main">
    <article class="post" data-pagefind-body>
      <h1 class="col-mb-12 post-title" data-pagefind-meta="title">
        <a href={Astro.url.pathname}>{title}</a>
      </h1>
      <ul class="col-mb-12 post-meta" data-pagefind-ignore>
        <li>著者：<a href={withTrailingSlash('/about')}>{author}</a></li>
        <li>{formatDate(pubDate)}</li>
        <li>{wordCount}字</li>
      </ul>
      <div class="col-mb-12 post-content">
        <slot />
      </div>
      
      {(categories.length > 0 || tags.length > 0) && (
        <div class="post-meta-bottom">
          {categories.length > 0 && (
            <span class="meta-item">
              カテゴリ：{
                categories.map((category, index) => (
                  <>
                    {index > 0 && ', '}
                    <a href={withTrailingSlash(`/categories/${encodeURIComponent(category)}`)}>{category}</a>
                  </>
                ))
              }
            </span>
          )}
          {categories.length > 0 && tags.length > 0 && (
            <span class="meta-separator"> / </span>
          )}
          {tags.length > 0 && (
            <span class="meta-item">
              タグ：{
                tags.map((tag, index) => (
                  <>
                    {index > 0 && ', '}
                    <a href={withTrailingSlash(`/tags/${encodeURIComponent(tag)}`)}>{tag}</a>
                  </>
                ))
              }
            </span>
          )}
        </div>
      )}
    </article>
    
    <slot name="comments" />
  </div>
</BaseLayout>

<style>
.post-meta-bottom {
    margin-top: 40px;
    padding-top: 20px;
  color: #666;
  font-size: 0.95em;
  line-height: 2;
}
.meta-item a {
  color: #3354AA;
  text-decoration: none;
  transition: all 0.2s ease;
}
.meta-item a:hover {
  color: #1a3d8f;
  text-decoration: underline;
}
.meta-separator {
  color: #999;
  margin: 0 8px;
}
html[data-theme="dark"] .post-meta-bottom {
    color: #999;
  }
html[data-theme="dark"] .meta-item a {
  color: #5a8bff;
}
html[data-theme="dark"] .meta-item a:hover {
  color: #7aa5ff;
}
</style>
