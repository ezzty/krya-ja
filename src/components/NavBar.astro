---
// 导航栏组件 - 支持滚动隐藏和移动端下拉菜单

interface Props {
  links?: Array<{ href: string; label: string }>;
}

const { 
  links = [
    { href: "/", label: "ホーム" },
    { href: "/archives/", label: "アーカイブ" },
    { href: "/search/", label: "検索" },
    { href: "/about/", label: "について" }
  ]
} = Astro.props;
---

<header class="cd-auto-hide-header">
  <div class="container">
    <div class="header-content">
      <div class="logo">
        <a href="/" class="logo-link">
          <svg class="logo-svg" xmlns="http://www.w3.org/2000/svg" width="61.208" height="28.708" viewBox="0 0 61.208 28.708">
            <g fill="#4D4D4D">
              <path d="M9.806 22.797l-5.87-7.975v7.975H.119V.056h3.817v13.713l5.58-7.159h4.58l-6.212 7.686 6.765 8.501H9.806zM25.888 6.425v3.396a7.233 7.233 0 0 0-1.184-.105c-1.176 0-2.123.368-2.844 1.105-.719.737-1.078 1.79-1.078 3.159v8.817h-3.817V10.321c0-1.509-.044-2.746-.131-3.711h3.316c.088.526.141 1.386.158 2.58.492-.965 1.123-1.698 1.895-2.198.773-.5 1.65-.75 2.633-.75.509-.001.858.061 1.052.183zM43.497 6.61l-8.106 22.137h-4.212l2.685-5.58L27.389 6.61h4.369l3.922 12.818L39.392 6.61h4.105zM61.054 19.086c0 1.702.035 2.938.105 3.711h-3.422c0-.07-.022-.32-.065-.75-.044-.43-.075-.979-.093-1.645a5.862 5.862 0 0 1-2.224 2.053c-.904.474-1.927.711-3.066.711-1.264 0-2.422-.355-3.475-1.066s-1.887-1.706-2.501-2.987-.921-2.746-.921-4.396c0-1.649.307-3.119.921-4.409.614-1.29 1.448-2.29 2.501-3.001a6.085 6.085 0 0 1 3.475-1.066c1.14 0 2.158.241 3.053.724a6.277 6.277 0 0 1 2.237 2.04c.018-.631.049-1.167.093-1.605.043-.438.065-.702.065-.79h3.422c-.07.772-.105 2.009-.105 3.711v8.765zm-3.843-4.369c0-1.649-.368-2.97-1.105-3.961-.737-.991-1.702-1.487-2.896-1.487-.772 0-1.461.224-2.066.671s-1.075 1.083-1.408 1.908c-.333.825-.5 1.781-.5 2.869 0 1.071.167 2.018.5 2.843.333.824.803 1.46 1.408 1.908a3.389 3.389 0 0 0 2.066.671c1.193 0 2.158-.496 2.896-1.487s1.105-2.303 1.105-3.935z"/>
            </g>
          </svg>
        </a>
        <!-- 暗黑模式切换按钮 - 放在 Logo 右边 -->
        <div class="logo-switches">
          <button id="theme-toggle" aria-label="ダークモード切替" title="ダークモード切替 (Alt + T)" accesskey="t">
            <svg id="moon" xmlns="http://www.w3.org/2000/svg" width="24" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
            <svg id="sun" xmlns="http://www.w3.org/2000/svg" width="24" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="5"/>
              <line x1="12" y1="1" x2="12" y2="3"/>
              <line x1="12" y1="21" x2="12" y2="23"/>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
              <line x1="1" y1="12" x2="3" y2="12"/>
              <line x1="21" y1="12" x2="23" y2="12"/>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
          </button>
        </div>
      </div>
      
      <!-- 桌面导航 -->
      <nav class="desktop-nav">
        <ul class="nav-list">
          {links.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))}
        </ul>
      </nav>
      
      <!-- 移动端汉堡菜单按钮 -->
      <button class="mobile-menu-toggle" aria-label="メニューを開く" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
      
      <!-- 下拉导航菜单 -->
      <div class="mobile-dropdown-menu">
        <ul class="nav-list">
          {links.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  (function() {
    // 暗黑模式切换按钮 - 使用 ThemeManager
    const themeToggleDesktop = document.querySelector('#theme-toggle');
    
    themeToggleDesktop?.addEventListener('click', function(e) {
      e.stopPropagation();
      window.ThemeManager?.toggleTheme();
    });
    
    // 导航菜单
    const menuToggle = document.querySelector('.mobile-menu-toggle');
    const dropdown = document.querySelector('.mobile-dropdown-menu');
    const header = document.querySelector('.cd-auto-hide-header');
    
    if (!menuToggle || !dropdown) return;
    
    menuToggle.addEventListener('click', function(e) {
      e.stopPropagation();
      const isOpen = this.getAttribute('aria-expanded') === 'true';
      this.setAttribute('aria-expanded', !isOpen);
      dropdown.classList.toggle('is-open');
      header.classList.toggle('menu-open');
      document.body.classList.toggle('menu-open');
    });
    
    document.addEventListener('click', function(e) {
      if (!dropdown.contains(e.target) && !menuToggle.contains(e.target)) {
        menuToggle.setAttribute('aria-expanded', 'false');
        dropdown.classList.remove('is-open');
        header.classList.remove('menu-open');
        document.body.classList.remove('menu-open');
      }
    });
    
    dropdown.querySelectorAll('a').forEach(function(link) {
      link.addEventListener('click', function() {
        menuToggle.setAttribute('aria-expanded', 'false');
        dropdown.classList.remove('is-open');
        header.classList.remove('menu-open');
        document.body.classList.remove('menu-open');
      });
    });
    
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && dropdown.classList.contains('is-open')) {
        menuToggle.setAttribute('aria-expanded', 'false');
        dropdown.classList.remove('is-open');
        header.classList.remove('menu-open');
        document.body.classList.remove('menu-open');
      }
    });
  })();
</script>

<style>
  .header-content {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 40px;
  }
  
  /* 移动端 header-content 左右边距 10px */
  @media (max-width: 1023px) {
    .header-content {
      margin-left: -21px;
      margin-right: -21px;
      padding-left: 10px;
      padding-right: 10px;
    }
    
    .logo {
      padding-left: 0px;
    }
  }
  
  @media (min-width: 1024px) {
    .header-content {
      height: 25px;
    }
    
    .logo {
      margin-left: -10px;
      gap: 4px;
    }
  }
  
  /* 桌面导航 */
  .desktop-nav {
    display: none;
  }
  
  .desktop-nav .nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 1em;
    border-bottom: none;
  }
  
  .desktop-nav a {
    color: #4d4d4d;
    text-decoration: none;
    border-bottom: none;
    font-size: 15px;
    transition: color 0.2s ease;
  }
  
  .desktop-nav a:hover,
  .desktop-nav a.active {
    color: #000000;
    text-decoration: none;
    border-bottom: none;
  }
  
  /* Logo 右边的暗黑模式切换按钮 - 参考 isming.me 风格 */
  .logo {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  
  /* Logo 样式 */
  .logo-svg {
    height: 28px;
    width: auto;
    display: block;
  }
  
  .logo-svg g {
    fill: #4d4d4d;
    transition: fill 0.2s ease;
  }
  
  html[data-theme="dark"] .logo-svg g {
    fill: #e0e0e0;
  }
  
  .logo-switches {
    display: inline-flex;
    margin: auto 0;
    flex-wrap: inherit;
  }
  
  #theme-toggle {
    font-size: 24px;
    margin: auto 4px;
    padding: 0;
    background: transparent;
    border: none;
    cursor: pointer;
    color: #4d4d4d;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  #theme-toggle:focus {
    outline: 0;
  }
  
  #theme-toggle svg {
    display: block;
  }
  
  #theme-toggle #sun {
    display: none;
  }
  
  #theme-toggle #moon {
    display: block;
  }
  
  html[data-theme="dark"] #theme-toggle {
    color: #e0e0e0;
  }

  html[data-theme="dark"] #theme-toggle #sun {
    display: block;
  }

  html[data-theme="dark"] #theme-toggle #moon {
    display: none;
  }

  html[data-theme="dark"] .desktop-nav a {
    color: #e0e0e0;
  }

  html[data-theme="dark"] .desktop-nav a:hover,
  html[data-theme="dark"] .desktop-nav a.active {
    color: #ffffff;
  }
  
  @media (min-width: 1024px) {
    .desktop-nav {
      display: flex;
      align-items: center;
    }
  }
  
  /* 汉堡菜单按钮 */
  .mobile-menu-toggle {
    display: block;
    width: 24px;
    height: 18px;
    padding: 0;
    background: transparent;
    border: none;
    cursor: pointer;
    z-index: 1001;
    position: relative;
  }
  
  .mobile-menu-toggle span {
    display: block;
    width: 100%;
    height: 2px;
    background-color: #25283D;
    position: absolute;
    left: 0;
    transition: all 0.3s ease;
    border-radius: 1px;
  }
  
  .mobile-menu-toggle span:nth-child(1) {
    top: 0;
  }
  
  .mobile-menu-toggle span:nth-child(2) {
    top: 50%;
    transform: translateY(-50%);
  }
  
  .mobile-menu-toggle span:nth-child(3) {
    bottom: 0;
  }
  
  .mobile-menu-toggle[aria-expanded="true"] span:nth-child(1) {
    top: 50%;
    transform: translateY(-50%) rotate(45deg);
  }
  
  .mobile-menu-toggle[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }
  
  .mobile-menu-toggle[aria-expanded="true"] span:nth-child(3) {
    bottom: 50%;
    transform: translateY(50%) rotate(-45deg);
  }
  
  /* 下拉菜单 */
  .mobile-dropdown-menu {
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    background-color: #ffffff;
    border-top: 1px solid #f2f2f2;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: all 0.3s ease;
    z-index: 999;
    overflow: hidden;
  }
  
  .mobile-dropdown-menu.is-open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  
  /* 通用导航列表样式（桌面端和移动端共用） */
  .nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .nav-list a {
    display: block;
    padding: 10px 10px;
    color: #4d4d4d;
    font-size: 16px;
    text-decoration: none;
    transition: background-color 0.2s ease;
  }
  
  .nav-list a:hover,
  .nav-list a:active {
    background-color: #f8f8f8;
    color: #000000;
  }
  
  /* 桌面端隐藏移动控件 */
  @media only screen and (min-width: 1024px) {
    .mobile-menu-toggle,
    .mobile-dropdown-menu {
      display: none;
    }
  }
  
  /* 移动端隐藏桌面导航 */
  @media only screen and (max-width: 1023px) {
    .desktop-nav {
      display: none;
    }
    
    /* 移动端下拉菜单特有样式 */
    .mobile-dropdown-menu .nav-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    
    .mobile-dropdown-menu .nav-list li {
      text-align: center;
      border-bottom: 1px solid #ececec;
    }
    
    .mobile-dropdown-menu .nav-list a {
      display: block;
      padding: 10px 10px;
      color: #4d4d4d;
      font-size: 16px;
      text-decoration: none;
      transition: background-color 0.2s ease;
    }
    
    .mobile-dropdown-menu .nav-list a:hover,
    .mobile-dropdown-menu .nav-list a:active {
      background-color: #f8f8f8;
      color: #000000;
    }
    
    html[data-theme="dark"] .mobile-dropdown-menu .nav-list li {
      border-bottom-color: #3a3a3a;
    }
  }
  
  /* 暗黑模式适配 */
  html[data-theme="dark"] .mobile-menu-toggle span {
    background-color: #e0e0e0;
  }

  html[data-theme="dark"] .mobile-dropdown-menu {
    background-color: #1a1a1a;
    border-top-color: #3a3a3a;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);
  }
  
  /* 通用暗黑模式样式 */
  html[data-theme="dark"] .nav-list a {
    color: #e0e0e0;
  }

  html[data-theme="dark"] .nav-list a:hover,
  html[data-theme="dark"] .nav-list a:active {
    background-color: #2a2a2a;
    color: #fff;
  }

  /* 菜单打开时隐藏 Pagefind 搜索图标和搜索内容 */
</style>

<style is:inline>
  /* 全局样式 - 菜单打开时隐藏搜索组件 */
  body.menu-open .pagefind-ui {
    visibility: hidden !important;
  }
  body.menu-open .pagefind-ui .pagefind-ui__form::before {
    visibility: hidden !important;
    opacity: 0 !important;
  }
</style>
